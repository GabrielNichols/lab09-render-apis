  "item": [
    {
      "name": "Exercicio 9.1 - Flask Local/Render",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{base_url_ex91}}/api/health" }
        },
        {
          "name": "Listar tarefas",
          "request": { "method": "GET", "url": "{{base_url_ex91}}/api/tasks" }
        },
        {
          "name": "Criar tarefa",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Nova tarefa via Postman\",\n  \"description\": \"Criada no exercicio 9.1\",\n  \"done\": false\n}"
            },
            "url": "{{base_url_ex91}}/api/tasks"
          }
        },
        {
          "name": "Atualizar tarefa",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tarefa atualizada\",\n  \"description\": \"Atualizada pelo Postman\",\n  \"done\": true\n}"
            },
            "url": "{{base_url_ex91}}/api/tasks/1"
          }
        },
        {
          "name": "Remover tarefa",
          "request": { "method": "DELETE", "url": "{{base_url_ex91}}/api/tasks/2" }
        }
      ]
    },
